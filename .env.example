# ============================================================================
# Transit-X Vercel Backend Configuration
# Copy to .env and fill with your actual credentials
# ============================================================================

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=production
PORT=8000

# ============================================================================
# Supabase Database
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# Google Maps API
# ============================================================================
# Get from: https://console.cloud.google.com
# Enable: Routes API, Maps Static API, Geocoding API
GOOGLE_MAPS_API_KEY=AIzaSy...

# ============================================================================
# HERE Maps API (Fallback)
# ============================================================================
# Get from: https://developer.here.com
# Provides transit routing and traffic data
HERE_API_KEY=YOUR_HERE_API_KEY

# ============================================================================
# Traffic Data
# ============================================================================
# TomTom Traffic API for road conditions and closures
# Get from: https://developer.tomtom.com
TOMTOM_API_KEY=YOUR_TOMTOM_API_KEY

# ============================================================================
# Weather Data
# ============================================================================
# OpenWeatherMap API for weather information
# Get from: https://openweathermap.org/api
# Plan: One Call API 3.0
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# ============================================================================
# GTFS-Realtime
# ============================================================================
# Public GTFS-Realtime feed URL (usually provided by transit authority)
# Format: https://gtfs-rt.example.com/vehicle_positions.pb or
#         https://example.com/gtfs-realtime/alerts
GTFS_REALTIME_URL=https://...

# ============================================================================
# Error Tracking (Sentry)
# ============================================================================
# Get from: https://sentry.io
# Used for: Error tracking, performance monitoring, release tracking
SENTRY_DSN=https://xxx@sentry.io/project-id

# ============================================================================
# Push Notifications (OneSignal)
# ============================================================================
# Get from: https://onesignal.com
# Used for: Push notifications to Flutter app
ONESIGNAL_API_KEY=YOUR_ONESIGNAL_API_KEY
ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID

# ============================================================================
# Machine Learning Model
# ============================================================================
# Path to trained ML model (pickle/joblib format)
# Place in: /models/delay_predictor.joblib
ML_MODEL_PATH=models/delay_predictor.joblib

# ============================================================================
# Database Connection Parameters (if needed directly)
# ============================================================================
DB_HOST=db.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_db_password

# ============================================================================
# Caching (Redis)
# ============================================================================
# Optional: For caching predictions and API responses
REDIS_URL=redis://localhost:6379

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# Rate Limiting
# ============================================================================
# Max requests per minute per IP
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============================================================================
# Vercel Specific
# ============================================================================
# Auto-detected by Vercel, but can be overridden
VERCEL_ENV=production
VERCEL_PROJECT_ID=your_project_id
VERCEL_TEAM_ID=your_team_id

# ============================================================================
# Feature Flags
# ============================================================================
# Enable/disable features during development
FEATURE_GOOGLE_MAPS=true
FEATURE_HERE_MAPS=true
FEATURE_GTFS_REALTIME=true
FEATURE_ML_MODEL=true
FEATURE_CROWDSOURCING=true
FEATURE_FLOOD_ALERTS=true
FEATURE_NOTIFICATIONS=true
